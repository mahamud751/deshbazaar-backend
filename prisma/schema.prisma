generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders    Order[]
  wishlists Wishlist[]
  ratings   Rating[]
  vendor    Vendor?

  @@map("users")
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?
  image       String?
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("categories")
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  oldPrice        Decimal? @map("old_price") @db.Decimal(10, 2)
  image           String
  images          String[]
  brand           String
  size            String?
  color           String?
  shippedFrom     String   @map("shipped_from")
  warranty        String
  deliveryOption  Boolean  @default(false) @map("delivery_option")
  promotions      String[]
  specifications  Json?
  categoryId      Int      @map("category_id")
  vendorId        Int      @map("vendor_id")
  isActive        Boolean  @default(true) @map("is_active")
  stockQuantity   Int      @default(0) @map("stock_quantity")
  rating          Decimal? @db.Decimal(2, 1)
  totalSold       Int      @default(0) @map("total_sold")
  hasVariants     Boolean  @default(false) @map("has_variants")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category     Category       @relation(fields: [categoryId], references: [id])
  vendor       Vendor         @relation(fields: [vendorId], references: [id])
  orderItems   OrderItem[]
  wishlists    Wishlist[]
  ratings      Rating[]
  flashSales   FlashSaleProduct[]
  variants     ProductVariant[]

  @@map("products")
}

model FlashSale {
  id          Int      @id @default(autoincrement())
  title       String
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products FlashSaleProduct[]

  @@map("flash_sales")
}

model FlashSaleProduct {
  id              Int     @id @default(autoincrement())
  flashSaleId     Int     @map("flash_sale_id")
  productId       Int     @map("product_id")
  discountPrice   Decimal @map("discount_price") @db.Decimal(10, 2)
  discountPercent Int     @map("discount_percent")

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([flashSaleId, productId])
  @@map("flash_sale_products")
}

model Order {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  orderNumber     String   @unique @map("order_number")
  totalAmount     Decimal  @map("total_amount") @db.Decimal(10, 2)
  deliveryCharge  Decimal  @default(70) @map("delivery_charge") @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  shippingAddress String   @map("shipping_address")
  billingAddress  String   @map("billing_address")
  paymentMethod   String   @map("payment_method")
  paymentStatus   String   @default("pending") @map("payment_status")
  shippedAt       DateTime? @map("shipped_at")
  deliveredAt     DateTime? @map("delivered_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id              Int     @id @default(autoincrement())
  orderId         Int     @map("order_id")
  productId       Int     @map("product_id")
  variantId       Int?    @map("variant_id")
  vendorId        Int     @map("vendor_id")
  productName     String  @map("product_name")
  productImage    String  @map("product_image")
  price           Decimal @db.Decimal(10, 2)
  quantity        Int
  total           Decimal @db.Decimal(10, 2)
  size            String?
  color           String?
  variantSku      String? @map("variant_sku")
  variantName     String? @map("variant_name")
  commissionRate  Decimal @map("commission_rate") @db.Decimal(5, 2)
  commissionAmt   Decimal @map("commission_amt") @db.Decimal(10, 2)
  vendorEarning   Decimal @map("vendor_earning") @db.Decimal(10, 2)
  itemStatus      OrderItemStatus @default(PENDING) @map("item_status")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  vendor  Vendor         @relation(fields: [vendorId], references: [id])

  @@map("order_items")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  productId Int      @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Rating {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  productId     Int      @map("product_id")
  vendorId      Int?     @map("vendor_id")
  rating        Decimal  @db.Decimal(2, 1)
  title         String?
  comment       String
  helpfulCount  Int      @default(0) @map("helpful_count")
  verified      Boolean  @default(false)
  approved      Boolean  @default(false)
  images        String[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor? @relation(fields: [vendorId], references: [id])

  @@map("ratings")
}

// ───────────────────────────────────────────────
// VENDOR MODEL - Multi-vendor marketplace support
// ───────────────────────────────────────────────
model Vendor {
  id              Int          @id @default(autoincrement())
  userId          Int          @unique @map("user_id")
  shopName        String      @map("shop_name")
  slug            String       @unique
  description     String?
  logo            String?
  banner          String?
  address         String?
  city            String?
  state           String?
  postalCode      String?      @map("postal_code")
  country         String       @default("Bangladesh")
  phone           String?
  email           String?
  commissionRate  Decimal      @map("commission_rate") @db.Decimal(5, 2)
  bankName        String?      @map("bank_name")
  bankAccount     String?      @map("bank_account")
  bankBranch      String?      @map("bank_branch")
  routingNumber   String?      @map("routing_number")
  status          VendorStatus @default(PENDING)
  totalProducts   Int          @default(0) @map("total_products")
  totalSales      Int          @default(0) @map("total_sales")
  totalRevenue    Decimal      @default(0) @map("total_revenue") @db.Decimal(12, 2)
  rating          Decimal?     @db.Decimal(2, 1)
  totalReviews    Int          @default(0) @map("total_reviews")
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id])
  products  Product[]
  orderItems OrderItem[]
  payouts   VendorPayout[]
  ratings   Rating[]

  @@map("vendors")
}

// ───────────────────────────────────────────────
// PRODUCT VARIANT MODEL - Size, Color, Material etc.
// ───────────────────────────────────────────────
model ProductVariant {
  id              Int          @id @default(autoincrement())
  productId       Int          @map("product_id")
  sku             String
  name            String
  variantAttributes Json       // e.g. {"color": "Red", "size": "XL", "material": "Cotton"}
  price           Decimal      @db.Decimal(10, 2)
  oldPrice        Decimal?    @map("old_price") @db.Decimal(10, 2)
  stock           Int          @default(0)
  image           String?
  status          VariantStatus @default(ACTIVE)
  weight          Decimal?     @db.Decimal(8, 2)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@unique([productId, sku])
  @@map("product_variants")
}

// ───────────────────────────────────────────────
// VENDOR PAYOUT MODEL
// ───────────────────────────────────────────────
model VendorPayout {
  id            Int          @id @default(autoincrement())
  vendorId      Int          @map("vendor_id")
  amount        Decimal      @db.Decimal(12, 2)
  commission    Decimal      @db.Decimal(12, 2)
  netAmount     Decimal      @map("net_amount") @db.Decimal(12, 2)
  status        PayoutStatus @default(PENDING)
  paymentMethod String       @map("payment_method")
  transactionId String?      @map("transaction_id")
  note          String?
  periodStart   DateTime     @map("period_start")
  periodEnd     DateTime     @map("period_end")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@map("vendor_payouts")
}

enum Role {
  USER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum OrderItemStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VariantStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
